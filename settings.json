{
  "permissions": {
    "allow": [
      "Bash(source ~/.nvm/nvm.sh *)",

      "Read(//Users/randy/workspace/**)",
      "Read(//Users/randy/claude_code/**)",
      "Read(//Users/randy/.claude/**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",

      "WebSearch",
      "WebFetch",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(env)",

      "Bash(git:*)",

      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npm ci:*)",
      "Bash(npm view:*)",
      "Bash(npm search:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm i:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm approve-builds:*)",
      "Bash(yarn install:*)",
      "Bash(yarn add:*)",
      "Bash(bun install:*)",
      "Bash(bun add:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(pip3 show:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv pip install:*)",
      "Bash(uv run:*)",

      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm test\\:web:*)",
      "Bash(pnpm test\\:e2e:*)",
      "Bash(yarn test:*)",
      "Bash(npx vitest:*)",
      "Bash(pnpm vitest:*)",
      "Bash(pnpm exec vitest:*)",
      "Bash(vitest:*)",
      "Bash(npx jest:*)",
      "Bash(jest:*)",
      "Bash(go test:*)",

      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "agent",
            "prompt": "A git commit was just made. Review the committed changes by running `git diff HEAD~1 HEAD` and `git log -1 --format='%s%n%n%b'`. Check for:\n1. Conventional Commits format compliance (type(scope): description)\n2. Atomic commit principle (one logical change per commit)\n3. Code quality issues (typos, debug code, TODO/FIXME left behind, trailing whitespace)\n4. Potential bugs or logic errors in the diff\n5. Security concerns (hardcoded secrets, credentials)\n\nProvide a brief review summary. If everything looks good, say so concisely. If there are issues, list them clearly with file and line references. Keep the review short and actionable.",
            "if": "Bash(git commit:*)",
            "timeout": 120,
            "model": "claude-sonnet-4-6",
            "statusMessage": "Reviewing commit..."
          }
        ]
      }
    ],
    "UserPromptSubmit": []
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-slides@frontend-slides": true
  },
  "extraKnownMarketplaces": {
    "frontend-slides": {
      "source": {
        "source": "git",
        "url": "https://github.com/zarazhangrui/frontend-slides.git"
      }
    }
  },
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
